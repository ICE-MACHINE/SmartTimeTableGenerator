@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
  --font-serif: "Playfair Display", serif;
}

:root {
  --bg: #05070A;
  --surface: #0D1117;
  --surface-glass: rgba(13, 17, 23, 0.7);
  --border: rgba(255, 255, 255, 0.08);
  --accent: #38BDF8; /* Sky Blue */
  --accent-glow: rgba(56, 189, 248, 0.3);
  --text-primary: #F0F6FC;
  --text-secondary: #8B949E;
  
  --f-serif: "Playfair Display", serif;
}

:root[data-theme="light"] {
  --bg: #f8fafc;
  --surface: #ffffff;
  --surface-glass: rgba(255, 255, 255, 0.8);
  --border: rgba(0, 0, 0, 0.08);
  --accent: #0284c7;
  --accent-glow: rgba(2, 132, 199, 0.3);
  --text-primary: #0f172a;
  --text-secondary: #475569;
}

body {
  margin: 0;
  font-family: var(--font-sans);
  background-color: var(--bg);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}

/* Glassmorphism Utility */
.glass {
  background: var(--surface-glass);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border);
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg);
}

::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text-secondary);
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fadeIn 0.5s ease forwards;
}

/* Grid Background */
.bg-grid {
  background-image: radial-gradient(var(--border) 1px, transparent 1px);
  background-size: 40px 40px;
}
@media print {
  /* إخفاء كل شيء في الصفحة */
  body * {
    visibility: hidden;
  }
  /* إظهار الجدول فقط وما بداخله */
  #printable-table, #printable-table * {
    visibility: visible;
  }
  /* تحديد مكان الجدول في أعلى الصفحة المطبوعة */
  #printable-table {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
  }
  /* إخفاء ظلال الـ Glassmorphism لتحسين جودة الطباعة */
  .glass {
    background: white !important;
    color: black !important;
    box-shadow: none !important;
    border: 1px solid #ccc !important;
  }
}
@page {
  size: landscape;
  margin: 10mm;
}
